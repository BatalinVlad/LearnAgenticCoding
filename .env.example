# Copy this file to `.env` in the project root and fill in values.
# See: https://unsplash.com/developers — use the "Access Key" (Client ID) only here.
# The Secret Key is not used by this app.

PORT=3000
# Board persistence: file (default, todos.json) | memory | mongo (not implemented yet)
BOARD_STORE=file
MONGODB_URI=

UNSPLASH_ACCESS_KEY=
